# ── Keycloak ──────────────────────────────────────────────────────
KC_HOSTNAME=auth.vaqueroisi.org
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=changeme
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=changeme

# ── OAuth2 Proxy ─────────────────────────────────────────────────
# Create a client in Keycloak under the "visi" realm:
#   Client ID: visi-lab
#   Client Secret: (generate in Keycloak)
OAUTH2_CLIENT_ID=visi-lab
OAUTH2_CLIENT_SECRET=changeme
KC_REALM=visi

# Generate cookie secret:
#   python3 -c 'import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())'
OAUTH2_COOKIE_SECRET=

# ── App ──────────────────────────────────────────────────────────
GEMINI_API_KEY=
APP_URL=https://vaqueroisi.org
